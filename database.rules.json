{
  "rules": {
    ".read": "auth != null && (auth.token.email === 'niranjanns1925@gmail.com' || (auth.token.email_verified === true && root.child('admins').child(auth.uid).exists()))",
    ".write": "auth != null && (auth.token.email === 'niranjanns1925@gmail.com' || (auth.token.email_verified === true && root.child('admins').child(auth.uid).exists()))",

    "presence": {
      "$uid": {
        ".read": "auth != null && auth.token.email_verified === true",
        ".write": "auth != null && auth.uid === $uid && auth.token.email_verified === true",
        "status": {
          ".validate": "newData.isString() && (newData.val() === 'online' || newData.val() === 'offline')"
        },
        "lastSeen": {
          ".validate": "newData.isNumber()"
        }
      }
    },

    "notifications": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && (auth.token.email === 'niranjanns1925@gmail.com' || (auth.token.email_verified === true && root.child('admins').child(auth.uid).exists()))",
        
        "$notificationId": {
          ".validate": "newData.hasChildren(['title', 'message', 'timestamp'])"
        }
      }
    },

    "system_status": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },

    "admins": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid"
      }
    }
  }
}
