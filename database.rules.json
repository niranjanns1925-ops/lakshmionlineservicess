{
  "rules": {
    /* 
      Security Rules for Lakshmi E-Sevai Maiyam (Realtime Database)
      Note: This is separate from Firestore. Use this for low-latency features 
      like live presence or real-time notification counts.
    */
    // Global Helper-like logic for Auth
    ".read": "auth != null && (auth.token.email === 'niranjanns1925@gmail.com' || (auth.token.email_verified === true && root.child('admins').child(auth.uid).exists()))",
    ".write": "auth != null && (auth.token.email === 'niranjanns1925@gmail.com' || (auth.token.email_verified === true && root.child('admins').child(auth.uid).exists()))",

    // User Presence (Active status)
    "presence": {
      "$uid": {
        // Any verified user can see if someone is online (for support features)
        ".read": "auth != null && auth.token.email_verified === true",
        // Only the user themselves can set their presence
        ".write": "auth != null && auth.uid === $uid && auth.token.email_verified === true",
        "status": {
          ".validate": "newData.isString() && (newData.val() === 'online' || newData.val() === 'offline')"
        },
        "lastSeen": {
          ".validate": "newData.isNumber()"
        }
      }
    },

    // Real-time Notifications (Low-latency delivery)
    "notifications": {
      "$uid": {
        // Users can only read their own notifications
        ".read": "auth != null && auth.uid === $uid",
        // Only admins can push notifications
        ".write": "auth != null && (auth.token.email === 'niranjanns1925@gmail.com' || (auth.token.email_verified === true && root.child('admins').child(auth.uid).exists()))",
        
        "$notificationId": {
          ".validate": "newData.hasChildren(['title', 'message', 'timestamp'])"
        }
      }
    },

    // Administrative Section
    "system_status": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },

    // Admin Reference (Mirroring the admins collection logic)
    "admins": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid"
      }
    }
  }
}
