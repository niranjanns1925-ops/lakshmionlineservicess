rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn(); // Relaxed for development/preview environment
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'niranjanns1925@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'niranjanns1925@gmail.com';
    }

    function isValidAdmin(data) {
      return data.keys().hasAll(['email', 'name', 'role', 'createdAt']) &&
             data.keys().size() >= 4 &&
             data.email is string &&
             data.name is string &&
             data.role == 'Admin' &&
             data.createdAt is timestamp;
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidAdmin(incoming());
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role', 'phone', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['User', 'Admin'] &&
             data.phone is string && data.phone.size() <= 15 &&
             data.createdAt is timestamp;
    }

    function isValidService(data) {
      return data.keys().hasAll(['name', 'category', 'description', 'icon', 'color', 'fee', 'gst', 'processingDays', 'status', 'requiredDocs', 'requestCount', 'createdAt']) &&
             data.keys().size() >= 12 && data.keys().size() <= 13 &&
             data.name is string && data.name.size() <= 100 &&
             data.fee is number && data.fee >= 0 &&
             data.status in ['active', 'inactive'] &&
             data.requiredDocs is list && data.requiredDocs.size() <= 20 &&
             data.requestCount is number &&
             data.createdAt is timestamp &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidRequest(data) {
      return data.keys().hasAll(['userId', 'userName', 'serviceId', 'serviceName', 'documents', 'total', 'status', 'submittedAt', 'updatedAt', 'adminRemark', 'timeline']) &&
             data.keys().size() == 11 &&
             data.userId == request.auth.uid &&
             data.serviceId is string &&
             exists(/databases/$(database)/documents/services/$(data.serviceId)) &&
             data.status in ['Pending', 'Under Review', 'Approved', 'Rejected', 'Completed'] &&
             data.documents is list && data.documents.size() <= 10 &&
             data.submittedAt is timestamp &&
             data.updatedAt is timestamp &&
             data.timeline is list;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'timestamp', 'read', 'type']) &&
             data.keys().size() == 6 &&
             data.userId is string &&
             data.title is string && data.title.size() <= 200 &&
             data.timestamp is timestamp &&
             data.read is bool;
    }

    // --- Collection Guards ---

    match /users/{userId} {
      allow get: if isValidId(userId) && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isValidId(userId) && isOwner(userId) && isValidUser(incoming()) && 
                       (incoming().role == 'User' || (isAdmin() && incoming().role == 'Admin')) && 
                       incoming().createdAt == request.time;
      allow update: if isValidId(userId) && ((isOwner(userId) && isValidUser(incoming()) && 
                         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone']) &&
                         incoming().role == existing().role) || 
                        isAdmin());
    }

    match /services/{serviceId} {
      allow get: if isValidId(serviceId) && isSignedIn();
      allow list: if isSignedIn();
      allow create: if isValidId(serviceId) && isAdmin() && isValidService(incoming()) && incoming().createdAt == request.time;
      allow update: if isValidId(serviceId) && ((isAdmin() && isValidService(incoming())) ||
                       (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['requestCount'])));
    }

    match /requests/{requestId} {
      // 8. Secure List Queries
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isValidId(requestId) && isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isValidId(requestId) && isVerified() && isValidRequest(incoming()) && 
                       incoming().status == 'Pending' && 
                       incoming().submittedAt == request.time;
      
      allow update: if isValidId(requestId) && (
        isVerified() && (
          // Action: Citizen cancel or update self
          (resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['documents', 'updatedAt']) && incoming().updatedAt == request.time) ||
          // Action: Admin status update
          (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'adminRemark', 'timeline', 'updatedAt']) && incoming().updatedAt == request.time)
        )
      );
    }

    match /notifications/{notificationId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || (isAdmin() && resource.data.userId == 'ADMIN'));
      allow get: if isOwner(resource.data.userId) || (isAdmin() && resource.data.userId == 'ADMIN');
      allow create: if isAdmin() || (isSignedIn() && incoming().userId == 'ADMIN');
      allow update: if (isOwner(resource.data.userId) || (isAdmin() && existing().userId == 'ADMIN')) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }

    match /whitelist/{email} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
